{
  "program": "main.py",
  "method": "bayes",
  "name": "pacs_ffd_bayesian_search",
  "metric": {
    "goal": "maximize",
    "name": "val.acc_avg"
  },
  "parameters": {
    "config_file": { "values": ["configs/ffd/ffd_pacs.json"] },
    "dataset": { "values": ["PACS"] },
    "server_method": { "values": ["FFDServer"] },
    "client_method": { "values": ["FFDClient"] },
    "num_rounds": { "values": [80] },
    "lr": { "values": [3e-5] },
    "ffd_alpha": {
      "min": 0.05,
      "max": 3.0,
      "distribution": "log_uniform_values"
    },
    "ffd_warmup_rounds": { "min": 3, "max": 30, "distribution": "int_uniform" },
    "ffd_lambda_var": {
      "min": 0.1,
      "max": 5.0,
      "distribution": "log_uniform_values"
    },
    "ffd_lambda_cov": {
      "min": 0.005,
      "max": 0.5,
      "distribution": "log_uniform_values"
    }
  },
  "run_cap": 50
}
